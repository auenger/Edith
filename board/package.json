{
  "name": "@edith/board",
  "version": "0.1.0",
  "private": true,
  "description": "EDITH Board - Web Dashboard for AI Knowledge Infrastructure",
  "scripts": {
    "dev": "next dev",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "next build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "next start",
    "start:server": "node dist/server/index.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:api": "playwright test --project=api",
    "test:e2e:pages": "playwright test --project=pages",
    "test:e2e:ws": "playwright test --project=ws"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fastify/cors": "^11.0.0",
    "@fastify/websocket": "^11.0.0",
    "@xyflow/react": "^12.10.2",
    "chokidar": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "fastify": "^5.2.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.460.0",
    "next": "^15.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/dagre": "^0.7.54",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
