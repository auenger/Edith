# JARVIS Configuration Template
# Generated by jarvis --init or copied during installation.
#
# Usage:
#   1. Copy this file to your workspace root as "jarvis.yaml"
#   2. Fill in the required fields (marked with REQUIRED)
#   3. Run "jarvis" to start the agent
#
# Environment variables:
#   Use ${VAR_NAME} syntax to reference environment variables.
#   Example: api_key: ${OPENAI_API_KEY}

# ── LLM Configuration ──────────────────────────────────
# REQUIRED: Choose your LLM provider and model.
llm:
  provider: openai          # REQUIRED: openai | anthropic | ollama | other
  model: gpt-4              # REQUIRED: Model identifier
  # api_key: ${OPENAI_API_KEY}  # Optional: API key (use env var recommended)
  # base_url: https://api.openai.com/v1  # Optional: Custom API endpoint

# ── Workspace Configuration ────────────────────────────
# REQUIRED: Define where JARVIS stores knowledge artifacts.
workspace:
  root: ./company-jarvis    # REQUIRED: Workspace root path for knowledge artifacts
  language: zh              # REQUIRED: Output language (zh | en)

# ── Repository List ────────────────────────────────────
# Optional: List source code repositories for JARVIS to scan and index.
repos: []
  # Example:
  # - name: user-service
  #   path: /path/to/user-service
  #   stack: java-spring
  # - name: order-service
  #   path: /path/to/order-service
  #   stack: go

# ── Agent Configuration ────────────────────────────────
# Optional: Fine-tune agent behavior. Defaults are shown below.
agent:
  token_budget:
    routing_table: 500          # Layer 0: routing table max tokens
    quick_ref: 2000             # Layer 1: quick reference max tokens
    distillate_fragment: 4000   # Layer 2: distillate fragment max tokens
  auto_refresh: true            # Auto-refresh knowledge on startup
  refresh_interval: 24h         # Refresh interval (e.g., 1h, 24h, 7d)
